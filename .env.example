# =============================================================================
# EventosOmega — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores.
# NUNCA comite o .env.local no repositório.
#
# Nota: o Prisma CLI lê variáveis via dotenv-cli a partir de .env.local
# (scripts npm run db:*). O Next.js também carrega .env.local automaticamente.
# =============================================================================

# -----------------------------------------------------------------------------
# Banco de Dados (PostgreSQL)
# Exemplo local: postgresql://user:password@localhost:5432/eventos_omega
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Conexão direta (sem pooler) — obrigatório para `prisma migrate` em produção (Neon/Vercel)
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# -----------------------------------------------------------------------------
# Autenticação (Auth.js v5 — obrigatório em produção)
# Gere com: openssl rand -base64 32
# -----------------------------------------------------------------------------
AUTH_SECRET="substitua_por_um_secret_forte"

# -----------------------------------------------------------------------------
# Mercado Pago
# Obtenha em: https://www.mercadopago.com.br/developers/panel/credentials
# Use credenciais de TESTE para desenvolvimento.
# -----------------------------------------------------------------------------

# Access Token da plataforma Moove (SECRET — app marketplace)
MERCADOPAGO_ACCESS_TOKEN="APP_USR-..."

# Credenciais OAuth da aplicação marketplace (painel MP → sua aplicação)
MERCADOPAGO_CLIENT_ID="123456789"
MERCADOPAGO_CLIENT_SECRET="seu_client_secret"

# Public Key (pode ser usada no frontend se necessário)
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY="APP_USR-..."

# Secret para validar assinatura dos webhooks (gerado no painel MP)
MERCADOPAGO_WEBHOOK_SECRET="seu_webhook_secret"

# -----------------------------------------------------------------------------
# E-mail transacional (Resend — https://resend.com)
# -----------------------------------------------------------------------------

# API Key do Resend (SECRET)
RESEND_API_KEY="re_..."

# Remetente verificado no Resend (domínio ou onboarding@resend.dev para testes)
EMAIL_FROM="EventosOmega <ingressos@seudominio.com.br>"

# -----------------------------------------------------------------------------
# Aplicação
# -----------------------------------------------------------------------------

# URL pública da aplicação (sem barra final)
# Usada para configurar os back_urls do Mercado Pago
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Desenvolvimento (opcional)
# Usado apenas quando ADMIN cria eventos em NODE_ENV=development
# -----------------------------------------------------------------------------
DEMO_ORGANIZER_ID="cuid_do_usuario_demo"
